<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NAM → NUX Converter"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/purple_500"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Convierte modelos NAM para NUX MG-300"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginBottom="24dp"/>

        <!-- Estado de conexión y progreso -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Esperando acción..."
            android:gravity="center"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="16dp"
            android:textSize="14sp"/>

        <!-- Archivo seleccionado -->
        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📄 Ningún archivo seleccionado"
            android:gravity="center"
            android:padding="8dp"
            android:textSize="14sp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="16dp"/>

        <!-- Botón: Seleccionar archivo -->
        <Button
            android:id="@+id/btnSelectFile"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📂 Seleccionar archivo NAM"
            android:layout_marginBottom="12dp"
            app:icon="@android:drawable/ic_menu_upload"
            app:iconGravity="textStart"/>

        <!-- Botón: Convertir -->
        <Button
            android:id="@+id/btnConvert"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🔄 Convertir a NUX"
            android:layout_marginBottom="12dp"
            android:enabled="false"/>

        <!-- Botón: Enviar a pedalera -->
        <Button
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📤 Enviar a pedalera"
            android:layout_marginBottom="12dp"
            android:enabled="false"/>

        <!-- Botón: Compartir -->
        <Button
            android:id="@+id/btnShare"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📤 Compartir archivo"
            android:layout_marginBottom="24dp"
            android:enabled="false"/>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/darker_gray"
            android:layout_marginVertical="16dp"/>

        <!-- Instrucciones -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📖 Instrucciones"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Conecta tu NUX MG-300 por USB\n2. Selecciona un archivo .nam\n3. Convierte a formato NUX\n4. Envía a la pedalera o comparte el archivo"
            android:textSize="13sp"
            android:lineSpacingExtra="4dp"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:textColor="@android:color/black"/>

    </LinearLayout>

</ScrollView>
