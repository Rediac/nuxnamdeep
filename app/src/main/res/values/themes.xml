<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- ============================================ -->
    <!-- Tema principal de la aplicación -->
    <!-- ============================================ -->
    <style name="Theme.Nuxnamdeep" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Colores primarios -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Colores secundarios -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Color de fondo -->
        <item name="android:windowBackground">@color/white</item>
        
        <!-- Color de la barra de estado -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        
        <!-- Color de la barra de navegación -->
        <item name="android:navigationBarColor">@color/white</item>
        
        <!-- Estilo de la barra de acción -->
        <item name="actionBarStyle">@style/Theme.Nuxnamdeep.ActionBar</item>
        
        <!-- Color de texto -->
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/gray_600</item>
        
        <!-- Fuente -->
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- ============================================ -->
    <!-- Estilo de la ActionBar -->
    <!-- ============================================ -->
    <style name="Theme.Nuxnamdeep.ActionBar" parent="Widget.MaterialComponents.ActionBar.Solid">
        <item name="background">@color/purple_500</item>
        <item name="titleTextColor">@color/white</item>
    </style>

    <!-- ============================================ -->
    <!-- Colores -->
    <!-- ============================================ -->
    <color name="purple_200">#FFBB86FC</color>
    <color name="purple_500">#FF6200EE</color>
    <color name="purple_700">#FF3700B3</color>
    <color name="teal_200">#FF03DAC5</color>
    <color name="teal_700">#FF018786</color>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>
    <color name="gray_600">#FF757575</color>
    <color name="gray_400">#FFBDBDBD</color>
    <color name="red_500">#FFF44336</color>
    <color name="green_500">#FF4CAF50</color>
</resources>
